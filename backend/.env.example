# Puerto del servidor backend
PORT=4000

# Secret para firmar JWT
JWT_SECRET=supersecretkeyforlocaldevelopment_safecampusucb

# Conexión a la base de datos PostgreSQL + PostGIS
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safecampus_ucb

# Google Client ID para autenticación vía SSO (para uso con Google Stitch/OAuth)
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
